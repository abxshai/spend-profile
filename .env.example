# Groq — required. The agent runs openai/gpt-oss-120b on Groq for extraction and chat.
GROQ_API_KEY=

# LlamaIndex Cloud (LlamaParse) — required for the OCR path. Get a key at
# https://cloud.llamaindex.ai/. Cost-effective tier is ~$0.00375/page; a 250-pg
# annual report ≈ $0.94.
LLAMA_CLOUD_API_KEY=

# Optional — pin LlamaParse parsing tier. Defaults to "cost_effective".
# Valid: "fast" (1 cr/pg), "cost_effective" (3 cr/pg), "agentic" (10 cr/pg).
LLAMA_PARSE_TIER=cost_effective

# Optional — Groq model id. Defaults to openai/gpt-oss-120b.
GROQ_MODEL=openai/gpt-oss-120b
