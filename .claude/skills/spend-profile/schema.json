{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SpendProfile",
  "type": "object",
  "required": [
    "company",
    "fiscal_year",
    "total_addressable_spend",
    "top_3_spend_categories",
    "yoy_cogs_change",
    "procurement_risks",
    "major_suppliers",
    "sales_angle"
  ],
  "properties": {
    "company": {
      "type": "object",
      "required": ["name", "ticker", "country"],
      "properties": {
        "name": { "type": "string" },
        "ticker": { "type": ["string", "null"] },
        "country": { "type": "string", "description": "ISO 3166 alpha-2" }
      }
    },
    "fiscal_year": { "type": "integer", "minimum": 2000, "maximum": 2030 },
    "total_addressable_spend": {
      "type": "object",
      "required": ["value_usd", "basis", "citation"],
      "properties": {
        "value_usd": { "type": ["number", "null"] },
        "basis": {
          "type": "string",
          "enum": ["cogs_plus_sga", "total_opex_ex_da_sbc", "revenue_proxy", "unavailable"]
        },
        "citation": { "$ref": "#/$defs/citation" }
      }
    },
    "top_3_spend_categories": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["category", "value_usd", "citation"],
        "properties": {
          "category": { "type": "string" },
          "value_usd": { "type": ["number", "null"] },
          "share_of_total": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
          "citation": { "$ref": "#/$defs/citation" }
        }
      }
    },
    "yoy_cogs_change": {
      "type": "object",
      "required": ["delta", "current_year_value_usd", "prior_year_value_usd", "citation"],
      "properties": {
        "delta": { "type": ["number", "null"], "description": "Decimal change, e.g. 0.087 = +8.7%" },
        "current_year_value_usd": { "type": ["number", "null"] },
        "prior_year_value_usd": { "type": ["number", "null"] },
        "citation": { "$ref": "#/$defs/citation" }
      }
    },
    "procurement_risks": {
      "type": "array",
      "minItems": 2,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["risk", "discovery_question", "citation"],
        "properties": {
          "risk": { "type": "string", "description": "One sentence summary of the procurement-relevant risk" },
          "discovery_question": { "type": "string", "description": "Question an AE can open with" },
          "citation": { "$ref": "#/$defs/citation" }
        }
      }
    },
    "major_suppliers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "citation"],
        "properties": {
          "name": { "type": "string" },
          "relationship": { "type": ["string", "null"] },
          "citation": { "$ref": "#/$defs/citation" }
        }
      }
    },
    "sales_angle": {
      "type": "string",
      "description": "Exactly 3 sentences. Written to the AE, not the prospect."
    },
    "notes": { "type": ["string", "null"] }
  },
  "$defs": {
    "citation": {
      "oneOf": [
        {
          "type": "object",
          "required": ["page", "quote", "source"],
          "properties": {
            "page": { "type": ["integer", "null"] },
            "quote": { "type": "string", "minLength": 8 },
            "source": { "type": "string", "enum": ["edgar", "ocr"] }
          }
        },
        { "type": "null" }
      ]
    }
  }
}
